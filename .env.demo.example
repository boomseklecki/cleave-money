# DEMO stack template. Copy to .env.demo and fill in. Used by the `api-demo` service
# (docker compose --profile demo). This is a PUBLIC, DISPOSABLE backend you can stand up to show Cleave to
# friends: guest login (DEMO_MODE) auto-seeds each visitor an isolated sample app, Plaid is SANDBOX only, and
# there are no Splitwise creds so "Connect Splitwise" stays unavailable. Share the one-tap link
# `https://<your-demo-host>/demo` — the app adopts this server and offers a "Start Demo" button. Keep DISTINCT
# from .env / .env.prod: its own JWT secret and Postgres volume. .env.demo is gitignored; secrets stay
# server-side and the iOS app never sees these.

# Core
APP_NAME=Cleave
DEFAULT_CURRENCY=USD
# NOTE: server name (set it to e.g. "Cleave Demo"), hard-delete toggles, sync/backup cadence, and invite
# policy are ADMIN-EDITABLE IN-APP now (Settings -> Server Settings), stored in the DB — not env vars.
API_TOKENS={}

# Guest login. Enables POST /auth/demo (name-only, no OAuth) which mints an ephemeral demo-* user and
# auto-seeds it an isolated sample app. 404 on prod/dev (where this is false).
DEMO_MODE=true

# Real auth. Generate a FRESH secret — do NOT reuse the dev/prod one (so their tokens can't authenticate
# here, and vice versa):  openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_REQUIRED=true
# Guests come in ONLY through /auth/demo (ephemeral demo-* identities, auto-enrolled). Leave the Apple/Google
# provider creds unset so nobody can OAuth-enroll on the demo box.
# Fresh DB — no legacy un-owned rows to backfill. Leave blank.
SCOPING_PRIMARY_OWNER=
# No admins on the public demo.
ADMIN_USERS=[]
# Optional on demo (only sandbox tokens are stored). Leave empty to store them as plaintext, or set a Fernet
# key to exercise encryption. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=[]
# Demo testers use guest login, but leave these set if you also want Apple/Google to work (they won't pass
# the empty allowlist above unless you add emails).
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# Postgres + MinIO bucket are pinned by docker-compose (db-demo / receipts-demo); these are placeholders
# the compose `environment:` overrides. Leave as-is.
DATABASE_URL=postgresql+asyncpg://cleave:cleave@db-demo:5432/cleave
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=cleave
MINIO_SECRET_KEY=cleave-secret
MINIO_BUCKET=receipts-demo
MINIO_SECURE=false

# Plaid SANDBOX. PLAID_ENV=sandbox with the SANDBOX secret (client_id is shared across envs). Sandbox banks
# don't require a redirect, but registering this lets OAuth-style sandbox flows work end-to-end; confirm the
# app's AASA serves /plaid/oauth* (APPLE_TEAM_ID set) if you exercise that path.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=https://<your-demo-host>/plaid/oauth

# No Splitwise on the demo: leave these blank so "Connect Splitwise" is unavailable.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=
SPLITWISE_USER_MAP={}

# Remote access (Compose-only; the API never reads these). See docs/OPERATIONS.md.
# Cloudflare Tunnel: point <your-demo-host> at http://api-demo:8000 (dashboard token here, or a locally-
# managed cloudflared/config.yml, auto-detected), then `--profile tunnel`. (Any public reverse proxy works;
# the demo just needs to be reachable at the host in your /demo share link.)
CLOUDFLARE_TUNNEL_TOKEN=
# Tailscale (tailnet-private): auth key + tailscale/serve.json (proxy to api-demo:8000), `--profile tailscale`.
TS_AUTHKEY=
TS_HOSTNAME=cleave-demo
TS_EXTRA_ARGS=

# Push relay key for the demo instance (register a key at the relay form). PUSH_RELAY_URL is set in
# docker-compose. Empty = demo push disabled.
PUSH_RELAY_API_KEY=
