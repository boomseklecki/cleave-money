# The DEFAULT, real self-hosted instance config. Copy to `.env` and fill in, then `docker compose up -d`.
# This is the only stack a self-hoster needs (production Plaid). The optional sandbox uses `.env.dev`
# (`--profile dev`) and the demo uses `.env.demo` (`--profile demo`). All real `.env*` files are gitignored;
# secrets stay server-side and the iOS app never sees them.

# Core
APP_NAME=Cleave
DEFAULT_CURRENCY=USD
# NOTE: server name, hard-delete toggles, sync/backup cadence + retention, and invite policy are ADMIN-
# EDITABLE IN-APP now (Settings -> Server Settings), stored in the DB — not env vars.
API_TOKENS={}

# Real auth. Generate a FRESH secret — do NOT reuse the dev one (so dev tokens can't authenticate here):
#   openssl rand -hex 32
AUTH_JWT_SECRET=
# Production should require auth.
AUTH_REQUIRED=true
# Enrollment is DB-backed: the first person to sign in claims the server (enrolled + admin); everyone after
# needs a single-use invite generated in-app (Settings -> Invite). No email allowlist to maintain here.
# Set to your /me identifier BEFORE `alembic upgrade head`: the 0020 migration backfills existing un-owned
# accounts/transactions/goals to this owner so per-caller scoping keeps them visible to you.
SCOPING_PRIMARY_OWNER=
# Admins (local identifiers) — see all people; reserved for gating settings. Set your /me identifier.
ADMIN_USERS=[]
# REQUIRED for production: Fernet keys encrypting Plaid/Splitwise access tokens at rest. Set BEFORE
# `alembic upgrade head` (the 0021 migration encrypts existing rows with it). The first key encrypts; keep
# old keys in the list to decrypt during rotation. Losing all keys means tokens must be re-linked (not data
# loss). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=[]
# HTTP hardening (both opt-in; empty = off, dev unchanged). ALLOWED_HOSTS rejects spoofed Host headers — behind
# the Cloudflare tunnel set it to every public + LAN hostname, e.g.
#   ALLOWED_HOSTS=["your-host.example.com","dev.your-host.example.com","your-lan-host","localhost"]
# CORS_ALLOWED_ORIGINS only matters for a browser client (the native app needs none).
ALLOWED_HOSTS=[]
CORS_ALLOWED_ORIGINS=[]
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# Postgres: docker-compose pins DATABASE_URL to the `db` service, so this is just a placeholder — leave as-is.
DATABASE_URL=postgresql+asyncpg://cleave:cleave@db:5432/cleave
# Postgres password. docker-compose reads this (`${POSTGRES_PASSWORD:-cleave}`) for BOTH the db server and the
# api's connection string, so the two always match. The `cleave` default is dev-only — set a strong random
# value before exposing the stack (e.g. `openssl rand -hex 24`).
POSTGRES_PASSWORD=cleave
MINIO_ENDPOINT=minio:9000
# These are BOTH the app's S3 credentials AND the MinIO server's root user/password (see docker-compose.yml).
# Rotate them together to strong random values (e.g. `openssl rand -hex 20` for the secret) + restart minio.
MINIO_ACCESS_KEY=cleave
MINIO_SECRET_KEY=cleave-secret
MINIO_BUCKET=receipts
BACKUPS_BUCKET=backups
MINIO_SECURE=false

# Off-device backup tier (restic). The backup TARGET (repo string) + on/off toggle are ADMIN-EDITABLE
# IN-APP (Settings -> Server Settings) — NOT here. Only the SECRETS live here (server-side, gitignored,
# never sent to the app). RESTIC_PASSWORD encrypts the off-device repo at rest; keep it SAFELY ESCROWED
# off-host alongside ENCRYPTION_KEYS (see docs/OPERATIONS.md - losing it makes the offsite copy
# unrecoverable). Provide whichever remote's credentials match your target:
#   - S3-compatible (AWS/B2/Wasabi):  target "s3:s3.amazonaws.com/bucket/path" + the two AWS_* keys below.
#   - rclone remote (Drive/Dropbox/…): target "rclone:REMOTE:path" + configure the remote via RCLONE_CONFIG_*
#     env vars or a mounted rclone.conf.
#   - SFTP over SSH (e.g. a NAS): target "sftp:<alias>:/<share>/path". Auth is an SSH KEY, not env - 
#     drop id_ed25519 + known_hosts + an ssh `config` (with a `Host <alias>`) into ./secrets/ssh, which the
#     api container mounts read-only at /root/.ssh (openssh-client ships in the image). Key must be root-owned
#     and 0600 or OpenSSH refuses it. Full runbook in docs/OPERATIONS.md.
# RESTIC_PASSWORD encrypts the repo regardless of target and is ALWAYS required for the off-device tier.
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Docker volume that holds this instance's Postgres data. A fresh install can leave these defaults; an
# EXISTING operator binds their current (project-prefixed) volumes here so no data migrates — e.g.
# MAIN_DB_VOLUME=cleave_db_data_prod and DEV_DB_VOLUME=cleave_db_data (and set MINIO_BUCKET to the
# bucket your data already lives in, e.g. receipts-prod / BACKUPS_BUCKET=backups-prod).
MAIN_DB_VOLUME=db_data
DEV_DB_VOLUME=db_data_dev

# Plaid PRODUCTION. PLAID_ENV=production with the PRODUCTION secret (client_id is shared across envs).
# Production OAuth banks REQUIRE PLAID_REDIRECT_URI: register this EXACT value in the Plaid dashboard
# (production), confirm the app's AASA serves /plaid/oauth* (APPLE_TEAM_ID set) and the iOS app handles
# the Universal Link. An unregistered value rejects every link token.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_REDIRECT_URI=https://your-host.example.com/plaid/oauth

# Splitwise (production app). Use the public https callback registered in your Splitwise app.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=https://your-host.example.com/auth/splitwise/callback
SPLITWISE_USER_MAP={}

# --- Public/remote access (pick one; all Compose-only, the API never reads these) ---
# Option A: Cloudflare Tunnel (remotely-managed). Create a tunnel + public hostnames in the dashboard,
# point them at http://api:8000 etc., paste its token here, and run `--profile tunnel`. For full local
# control instead, copy cloudflared/config.yml.example -> cloudflared/config.yml (auto-detected).
CLOUDFLARE_TUNNEL_TOKEN=
# Option B: Tailscale (tailnet-private by default). Set an auth key, copy tailscale/serve.json.example ->
# tailscale/serve.json, and run `--profile tailscale`; reach the backend at
# https://${TS_HOSTNAME}.<your-tailnet>.ts.net from devices on your tailnet (point the app there). For
# PUBLIC exposure, flip the AllowFunnel line in serve.json from false to true (+ enable Funnel in your
# tailnet ACLs). TS_EXTRA_ARGS passes extra `tailscale up` flags (e.g. --advertise-tags=tag:cleave).
TS_AUTHKEY=
TS_HOSTNAME=cleave
TS_EXTRA_ARGS=

# Push notifications go through the push relay (this server holds no Apple creds). Register your instance
# at your relay's public URL for an API key. PUSH_RELAY_URL is set in docker-compose (http://relay:8000)
# if you run the relay container; override here to point at a VPS. Empty key = push disabled.
PUSH_RELAY_API_KEY=
# PUSH_RELAY_URL=https://push.your-host.example.com
