{
  "module": "matching",
  "reference": "ios/CleaveAPI/Sources/CleaveAPI/Logic/TransactionMatcher.swift",
  "note": "tokens(text): lowercase, split on any non-letter/non-digit, keep tokens of length >= 2 that are not stop words (payment plumbing / legal suffixes). Compared as an unordered set. NOTE: this stopword set differs from MerchantText's noise set.",
  "cases": [
    { "name": "brand-with-store-number", "fn": "matchTokens", "input": { "text": "Blue Bottle Coffee 0123" }, "expected": { "tokens": ["blue", "bottle", "coffee", "0123"] } },
    { "name": "all-stopwords-empty", "fn": "matchTokens", "input": { "text": "The Payment ACH LLC" }, "expected": { "tokens": [] } },
    { "name": "domain-keeps-com", "fn": "matchTokens", "input": { "text": "Netflix.com" }, "expected": { "tokens": ["netflix", "com"] } },
    { "name": "single-chars-dropped", "fn": "matchTokens", "input": { "text": "A B CD" }, "expected": { "tokens": ["cd"] } },
    { "name": "punctuation-split", "fn": "matchTokens", "input": { "text": "SQ *BLUE-BOTTLE" }, "expected": { "tokens": ["sq", "blue", "bottle"] } }
  ]
}
