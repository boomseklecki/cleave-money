{
  "module": "household-budget",
  "reference": "ios/CleaveAPI/Sources/CleaveAPI/Logic/HouseholdBudget.swift",
  "note": "combinedByCategory(month): over shared-group expenses in the month, each member's per-category owed share via ItemizedSpend.categoryContributions with a DETERMINISTIC empty lookup (so both partners' devices compute the same canonical category). mine = viewer's share; partnerTotal = sum of partners' shares; combined = mine + partnerTotal. Non-shared groups and other months are excluded. Dates are noon-UTC (tz-stable).",
  "cases": [
    { "name": "split-no-items", "fn": "combinedByCategory",
      "input": { "month": "2025-06-15T12:00:00Z", "viewer": "v", "partners": ["p"],
        "sharedGroupIds": ["11111111-1111-1111-1111-111111111111"],
        "expenses": [
          { "id": "eeeeeeee-0000-0000-0000-000000000001", "groupId": "11111111-1111-1111-1111-111111111111", "amount": "100", "category": "Groceries", "splitwise": false, "date": "2025-06-15T12:00:00Z",
            "splits": [ { "userIdentifier": "v", "paidShare": "100", "owedShare": "60" }, { "userIdentifier": "p", "paidShare": "0", "owedShare": "40" } ], "items": [] }
        ] },
      "expected": { "byCategory": { "Groceries": { "mine": "60", "partnerTotal": "40", "combined": "100" } } } },

    { "name": "itemized-owners-per-member", "fn": "combinedByCategory",
      "input": { "month": "2025-06-15T12:00:00Z", "viewer": "v", "partners": ["p"],
        "sharedGroupIds": ["11111111-1111-1111-1111-111111111111"],
        "expenses": [
          { "id": "eeeeeeee-0000-0000-0000-000000000002", "groupId": "11111111-1111-1111-1111-111111111111", "amount": "100", "category": "Groceries", "splitwise": false, "date": "2025-06-15T12:00:00Z",
            "splits": [ { "userIdentifier": "v", "paidShare": "100", "owedShare": "60" }, { "userIdentifier": "p", "paidShare": "0", "owedShare": "40" } ],
            "items": [ { "category": "Groceries", "price": "60", "owner": "v" }, { "category": "Dining", "price": "40", "owner": "p" } ] }
        ] },
      "expected": { "byCategory": {
        "Groceries": { "mine": "60", "partnerTotal": "0", "combined": "60" },
        "Dining": { "mine": "0", "partnerTotal": "40", "combined": "40" } } } },

    { "name": "excludes-nonshared-and-other-month", "fn": "combinedByCategory",
      "input": { "month": "2025-06-15T12:00:00Z", "viewer": "v", "partners": ["p"],
        "sharedGroupIds": ["11111111-1111-1111-1111-111111111111"],
        "expenses": [
          { "id": "eeeeeeee-0000-0000-0000-000000000003", "groupId": "22222222-2222-2222-2222-222222222222", "amount": "100", "category": "Groceries", "splitwise": false, "date": "2025-06-15T12:00:00Z",
            "splits": [ { "userIdentifier": "v", "paidShare": "0", "owedShare": "99" } ], "items": [] },
          { "id": "eeeeeeee-0000-0000-0000-000000000004", "groupId": "11111111-1111-1111-1111-111111111111", "amount": "100", "category": "Groceries", "splitwise": false, "date": "2025-05-15T12:00:00Z",
            "splits": [ { "userIdentifier": "v", "paidShare": "0", "owedShare": "88" } ], "items": [] },
          { "id": "eeeeeeee-0000-0000-0000-000000000005", "groupId": "11111111-1111-1111-1111-111111111111", "amount": "100", "category": "Groceries", "splitwise": false, "date": "2025-06-15T12:00:00Z",
            "splits": [ { "userIdentifier": "v", "paidShare": "0", "owedShare": "30" } ], "items": [] }
        ] },
      "expected": { "byCategory": { "Groceries": { "mine": "30", "partnerTotal": "0", "combined": "30" } } } }
  ]
}
