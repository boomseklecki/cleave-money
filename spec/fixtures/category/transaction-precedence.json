{
  "module": "category",
  "reference": "ios/CleaveAPI/Sources/CleaveAPI/Logic/CategoryMapping.swift",
  "note": "resolve(for transaction:lookup:sources:). Precedence: override -> local lookup -> per-row AI refinement -> Plaid built-in -> passthrough. Refinement outranks the built-in map. When raw is null/empty, a refinement is the only signal (aiRefined) else {null, raw}.",
  "cases": [
    { "name": "override-wins", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "FOOD_AND_DRINK_GROCERIES", "override": "Dining", "refined": null, "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Dining", "source": "override" } },
    { "name": "mapped-by-you", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "CUSTOM_RAW", "override": null, "refined": null, "source": "plaid" }, "lookup": { "CUSTOM_RAW": "Shopping" }, "sources": { "CUSTOM_RAW": "manual" } },
      "expected": { "category": "Shopping", "source": "mappedByYou" } },
    { "name": "mapped-by-ai", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "CUSTOM_RAW", "override": null, "refined": null, "source": "plaid" }, "lookup": { "CUSTOM_RAW": "Shopping" }, "sources": { "CUSTOM_RAW": "ondevice" } },
      "expected": { "category": "Shopping", "source": "mappedByAI" } },
    { "name": "deterministic-plaid", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "FOOD_AND_DRINK_GROCERIES", "override": null, "refined": null, "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Groceries", "source": "deterministic" } },
    { "name": "ai-refined-over-vague-builtin", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "GENERAL_SERVICES", "override": null, "refined": "Shopping", "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Shopping", "source": "aiRefined" } },
    { "name": "ai-refined-over-confident-builtin", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "FOOD_AND_DRINK_GROCERIES", "override": null, "refined": "Dining", "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Dining", "source": "aiRefined" } },
    { "name": "refined-on-null-raw", "fn": "resolveTransaction",
      "input": { "transaction": { "category": null, "override": null, "refined": "Shopping", "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Shopping", "source": "aiRefined" } },
    { "name": "override-beats-refined", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "FOOD_AND_DRINK", "override": "Travel", "refined": "Shopping", "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Travel", "source": "override" } },
    { "name": "raw-passthrough", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "ZZZ_UNKNOWN_LABEL", "override": null, "refined": null, "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "ZZZ_UNKNOWN_LABEL", "source": "raw" } },
    { "name": "explicit-canonical-passthrough", "fn": "resolveTransaction",
      "input": { "transaction": { "category": "Dining", "override": null, "refined": null, "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": "Dining", "source": "explicit" } },
    { "name": "null-raw-no-refined", "fn": "resolveTransaction",
      "input": { "transaction": { "category": null, "override": null, "refined": null, "source": "plaid" }, "lookup": {}, "sources": {} },
      "expected": { "category": null, "source": "raw" } }
  ]
}
