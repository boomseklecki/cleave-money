# Cleave distribution config. Copy to `.env`, fill in the REQUIRED secrets below, then `docker compose up -d`.
# The compose file pins DATABASE_URL / MINIO_ENDPOINT / RUN_MIGRATIONS, so you only edit values here.
# Keep this file server-side (it is gitignored); the iOS app never sees it.

# ---------------------------------------------------------------------------
# REQUIRED - generate a fresh value for each before the first boot.
# ---------------------------------------------------------------------------

# HS256 signing secret for auth tokens. Generate: openssl rand -hex 32
AUTH_JWT_SECRET=

# Fernet key(s) that encrypt Plaid/Splitwise access tokens at rest. The first key encrypts; keep older keys
# in the list to decrypt during rotation. A fresh install has nothing to encrypt yet, but this must be set
# before the first boot (migration 0021 reads it). Losing all keys means re-linking banks, not data loss.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=[]

# Postgres password (also the DB the API connects to). Generate: openssl rand -hex 20
POSTGRES_PASSWORD=

# MinIO object-storage credentials. These are BOTH the app's S3 keys AND the MinIO server root user/password.
# Generate the secret: openssl rand -hex 20
MINIO_ACCESS_KEY=cleave
MINIO_SECRET_KEY=

# ---------------------------------------------------------------------------
# Common options - sane defaults; change if you need them.
# ---------------------------------------------------------------------------

APP_NAME=Cleave
DEFAULT_CURRENCY=USD
AUTH_REQUIRED=true

# Fresh install: leave blank. The first person to sign in claims the server (enrolled + admin); everyone
# after needs a single-use invite generated in-app (Settings -> Invite). Only set this if you are importing
# existing un-owned data (it backfills those rows to your /me identifier during migration 0020).
SCOPING_PRIMARY_OWNER=
ADMIN_USERS=[]

# Reject spoofed Host headers once you expose the API. Set to every hostname you serve it on, e.g.
#   ALLOWED_HOSTS=["cleave.example.com","cleave.your-tailnet.ts.net","localhost"]
# Empty = accept any Host (fine on a trusted LAN). CORS only matters for a browser client; the app needs none.
ALLOWED_HOSTS=[]
CORS_ALLOWED_ORIGINS=[]

# Sign-in providers (leave blank to disable a provider).
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# ---------------------------------------------------------------------------
# Integrations - optional; leave blank to skip.
# ---------------------------------------------------------------------------

# Plaid (bank aggregation). PLAID_ENV is "production" or "sandbox"; production OAuth banks require the exact
# PLAID_REDIRECT_URI registered in your Plaid dashboard.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_REDIRECT_URI=https://cleave.example.com/plaid/oauth

# Splitwise (expense-splitting interop). Use the https callback registered in your Splitwise app.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=https://cleave.example.com/auth/splitwise/callback
SPLITWISE_USER_MAP={}

# Push notifications route through the shared relay (this server holds no Apple creds). Register your instance
# at the relay's public URL for a key. Empty key = push disabled. Point PUSH_RELAY_URL at the relay you use.
PUSH_RELAY_API_KEY=
# PUSH_RELAY_URL=https://push.example.com

# Off-device backups (restic, optional/advanced). The target + on/off toggle are admin-editable in-app; only
# the encryption secret lives here. Keep it escrowed off-host. See ../docs/OPERATIONS.md.
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
